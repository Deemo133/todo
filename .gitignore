# ============================================================
# 依存パッケージ（npm install で再生成可能）
# ============================================================
node_modules/

# ============================================================
# ビルド成果物（npm run build で再生成可能）
# ============================================================
dist/

# ============================================================
# TypeScript ビルドキャッシュ
# ============================================================
node_modules/.tmp/
*.tsbuildinfo

# ============================================================
# テストカバレッジ出力（vitest --coverage で生成）
# ============================================================
coverage/

# ============================================================
# エディタ・ツールのローカル設定
# ============================================================
.claude/
.vscode/
.idea/

# ============================================================
# OS が自動生成するファイル
# ============================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini

# ============================================================
# 環境変数・シークレット（誤ってコミットしないよう明示）
# ============================================================
.env
.env.local
.env.*.local
